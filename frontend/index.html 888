    <script>
        // Global variables
        let currentUser = null;
        let socket = null;
        let mainChart = null;
        let chartData = [];
        let activeIndicators = [];
        let realTimeInterval;
        
        // Initialize WebSocket (will connect after backend deploy)
        function initWebSocket() {
            // Backend URL - isko apne render URL se replace karna
            const BACKEND_URL = 'https://quantpro-backend.onrender.com';
            try {
                socket = io(BACKEND_URL, { transports: ['websocket'], autoConnect: true });
                socket.on('connect', () => showToast('Connected to real-time server', 'success'));
                socket.on('priceUpdate', (data) => updateRealTimePrice(data));
                socket.on('newSignal', (signal) => updateLiveSignal(signal));
                socket.on('disconnect', () => console.log('Disconnected'));
            } catch(e) { console.log('WebSocket not connected yet'); }
        }
        
        // Real-time price simulation (fallback)
        function startRealTimePrices() {
            realTimeInterval = setInterval(() => {
                const symbols = ['BTCUSD', 'ETHUSD', 'AAPL', 'GOOGL', 'TSLA'];
                const randomSymbol = symbols[Math.floor(Math.random() * symbols.length)];
                const basePrice = randomSymbol === 'BTCUSD' ? 43500 : randomSymbol === 'ETHUSD' ? 3200 : randomSymbol === 'AAPL' ? 175 : randomSymbol === 'GOOGL' ? 140 : 240;
                const price = basePrice + (Math.random() - 0.5) * basePrice * 0.02;
                updateChart(price);
            }, 3000);
            
            // Generate signals
            setInterval(() => {
                const type = Math.random() > 0.5 ? 'BUY' : 'SELL';
                const basePrice = 2350;
                updateLiveSignal({ type, entry: basePrice, sl: type === 'BUY' ? basePrice - 5 : basePrice + 5, tp: type === 'BUY' ? basePrice + 10 : basePrice - 10 });
            }, 30000);
        }
        
        // Trading Chart with Indicators
        function initTradingChart() {
            const ctx = document.getElementById('tradingChart').getContext('2d');
            chartData = generateMockCandleData(100);
            mainChart = new Chart(ctx, {
                type: 'candlestick',
                data: { datasets: [{ label: 'Price', data: chartData, borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.1)' }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: 'white' } } } }
            });
        }
        
        function generateMockCandleData(count) {
            let data = [], price = 43500;
            for (let i = 0; i < count; i++) {
                let open = price, close = price + (Math.random() - 0.5) * 200;
                data.push({ x: new Date(Date.now() - (count - i) * 60000), o: open, h: Math.max(open, close) + Math.random() * 100, l: Math.min(open, close) - Math.random() * 100, c: close });
                price = close;
            }
            return data;
        }
        
        function updateChart(newPrice) {
            if (!mainChart) return;
            let lastCandle = chartData[chartData.length - 1];
            if (lastCandle && new Date() - lastCandle.x < 60000) {
                lastCandle.c = newPrice;
                lastCandle.h = Math.max(lastCandle.h, newPrice);
                lastCandle.l = Math.min(lastCandle.l, newPrice);
            } else {
                chartData.push({ x: new Date(), o: lastCandle?.c || newPrice, h: newPrice, l: newPrice, c: newPrice });
                if (chartData.length > 100) chartData.shift();
            }
            mainChart.update();
            updateIndicators();
        }
        
        // Technical Indicators
        function addIndicator(type) {
            if (activeIndicators.includes(type)) return;
            activeIndicators.push(type);
            updateIndicators();
            showToast(`${type} indicator added`, 'success');
        }
        
        function clearIndicators() { activeIndicators = []; updateIndicators(); showToast('All indicators cleared', 'info'); }
        
        function updateIndicators() {
            const prices = chartData.map(c => c.c);
            const panel = document.getElementById('indicatorPanel');
            panel.innerHTML = '';
            
            if (activeIndicators.includes('MA') && prices.length >= 20) {
                const ma20 = calculateMA(prices, 20);
                panel.innerHTML += `<div class="bg-gray-700 p-3 rounded"><p class="text-blue-500">MA(20)</p><p class="text-white text-xl">${ma20[ma20.length-1]?.toFixed(2) || 'N/A'}</p></div>`;
            }
            if (activeIndicators.includes('RSI') && prices.length >= 14) {
                const rsi = calculateRSI(prices, 14);
                const rsiValue = rsi[rsi.length-1]?.toFixed(2) || 'N/A';
                const rsiColor = rsiValue > 70 ? 'text-red-500' : rsiValue < 30 ? 'text-green-500' : 'text-yellow-500';
                panel.innerHTML += `<div class="bg-gray-700 p-3 rounded"><p class="text-green-500">RSI(14)</p><p class="${rsiColor} text-xl">${rsiValue}</p></div>`;
            }
            if (activeIndicators.includes('MACD') && prices.length >= 26) {
                const macd = calculateMACD(prices);
                panel.innerHTML += `<div class="bg-gray-700 p-3 rounded"><p class="text-purple-500">MACD</p><p class="text-white text-xl">${macd.histogram[macd.histogram.length-1]?.toFixed(2) || 'N/A'}</p></div>`;
            }
        }
        
        function calculateMA(data, period) { let result = []; for (let i = period-1; i < data.length; i++) { let sum = 0; for (let j = 0; j < period; j++) sum += data[i-j]; result.push(sum/period); } return result; }
        function calculateRSI(data, period) { let gains = 0, losses = 0, rsi = []; for (let i = 1; i < data.length; i++) { let change = data[i] - data[i-1]; if (change >= 0) gains += change; else losses -= change; if (i >= period) { let avgGain = gains/period, avgLoss = losses/period; rsi.push(100 - (100 / (1 + avgGain/avgLoss))); } } return rsi; }
        function calculateMACD(data) { let ema12 = [], ema26 = [], macd = [], signal = [], histogram = []; for (let i = 0; i < data.length; i++) { ema12.push(data[i]); ema26.push(data[i]); if (i >= 26) { macd.push(ema12[i] - ema26[i]); if (i >= 34) { let sig = macd.slice(-9).reduce((a,b)=>a+b,0)/9; signal.push(sig); histogram.push(macd[i] - sig); } } } return { macd, signal, histogram }; }
        
        // Live Signal
        function updateLiveSignal(signal) {
            const signalDiv = document.getElementById('liveSignal');
            const signalType = document.getElementById('signalType');
            signalType.textContent = signal.type;
            signalType.className = `text-4xl font-bold mb-3 ${signal.type === 'BUY' ? 'text-green-500' : 'text-red-500'}`;
            signalDiv.className = `bg-gray-700/50 rounded-xl p-6 text-center ${signal.type === 'BUY' ? 'signal-buy' : 'signal-sell'}`;
            document.getElementById('signalEntry').textContent = signal.entry?.toFixed(2) || signal.entry;
            document.getElementById('signalSL').textContent = signal.sl?.toFixed(2) || signal.sl;
            document.getElementById('signalTP').textContent = signal.tp?.toFixed(2) || signal.tp;
        }
        
        function updateRealTimePrice(data) { }
        
        // Order Management
        document.getElementById('orderForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!currentUser) { showToast('Please login first', 'error'); showLogin(); return; }
            const order = { 
                userId: currentUser.email, 
                type: document.getElementById('orderType').value, 
                entry: parseFloat(document.getElementById('entryPrice').value), 
                sl: parseFloat(document.getElementById('stopLoss').value), 
                tp: parseFloat(document.getElementById('takeProfit').value), 
                quantity: parseFloat(document.getElementById('quantity').value), 
                symbol: document.getElementById('symbolSelect')?.value || 'BTCUSD', 
                timestamp: new Date().toISOString() 
            };
            let orders = JSON.parse(localStorage.getItem('orders') || '[]');
            orders.push(order);
            localStorage.setItem('orders', JSON.stringify(orders));
            updatePortfolio();
            updateHistory();
            updateDashboard();
            showToast('Order placed successfully!', 'success');
            e.target.reset();
        });
        
        function updatePortfolio() {
            let orders = JSON.parse(localStorage.getItem('orders') || '[]');
            let portfolio = orders.filter(o => !o.exitTime);
            let tableBody = document.getElementById('portfolioTable');
            if (tableBody) { 
                tableBody.innerHTML = ''; 
                portfolio.slice(-10).forEach(order => { 
                    let row = tableBody.insertRow(); 
                    row.innerHTML = `<td class="py-2">${order.symbol}</td><td class="${order.type === 'BUY' ? 'text-green-500' : 'text-red-500'}">${order.type}</td><td>$${order.entry}</td><td>$${order.entry}</td><td>${order.quantity}</td><td class="text-yellow-500">$0</td><td><button onclick="closePosition('${order.timestamp}')" class="bg-red-600 px-3 py-1 rounded text-sm">Close</button></td>`; 
                }); 
            }
            document.getElementById('openPositions').innerText = portfolio.length;
        }
        
        function updateHistory() {
            let orders = JSON.parse(localStorage.getItem('orders') || '[]');
            let closed = orders.filter(o => o.exitTime);
            let tableBody = document.getElementById('historyTable');
            if (tableBody) { 
                tableBody.innerHTML = ''; 
                closed.slice(-20).reverse().forEach(order => { 
                    let pnl = order.exitPrice ? ((order.type === 'BUY' ? order.exitPrice - order.entry : order.entry - order.exitPrice) * order.quantity).toFixed(2) : 0; 
                    let row = tableBody.insertRow(); 
                    row.innerHTML = `<td class="py-2">${new Date(order.exitTime || order.timestamp).toLocaleString()}</td><td>${order.symbol}</td><td class="${order.type === 'BUY' ? 'text-green-500' : 'text-red-500'}">${order.type}</td><td>$${order.entry}</td><td>$${order.exitPrice || '-'}</td><td class="${pnl >= 0 ? 'text-green-500' : 'text-red-500'}">$${pnl}</td><td>Closed</td>`; 
                }); 
            }
            updateDashboard();
        }
        
        function updateDashboard() {
            let orders = JSON.parse(localStorage.getItem('orders') || '[]');
            let closedTrades = orders.filter(o => o.exitPrice);
            let totalPnL = closedTrades.reduce((sum, o) => sum + ((o.type === 'BUY' ? o.exitPrice - o.entry : o.entry - o.exitPrice) * o.quantity), 0);
            let winning = closedTrades.filter(o => (o.type === 'BUY' ? o.exitPrice > o.entry : o.exitPrice < o.entry)).length;
            let winRate = closedTrades.length ? ((winning/closedTrades.length)*100) : 0;
            let pnls = closedTrades.map(o => (o.type === 'BUY' ? o.exitPrice - o.entry : o.entry - o.exitPrice) * o.quantity);
            let bestTrade = Math.max(...pnls, 0);
            let worstTrade = Math.min(...pnls, 0);
            let avgPnL = pnls.length ? pnls.reduce((a,b)=>a+b,0)/pnls.length : 0;
            let totalProfit = pnls.filter(p=>p>0).reduce((a,b)=>a+b,0);
            let totalLoss = Math.abs(pnls.filter(p=>p<0).reduce((a,b)=>a+b,0));
            let profitFactor = totalLoss ? (totalProfit/totalLoss).toFixed(2) : totalProfit ? '∞' : 0;
            
            document.getElementById('totalPnL').innerText = `$${totalPnL.toFixed(2)}`;
            document.getElementById('winRate').innerText = winRate.toFixed(1) + '%';
            document.getElementById('totalTrades').innerText = orders.length;
            document.getElementById('bestTrade').innerText = `$${bestTrade.toFixed(2)}`;
            document.getElementById('worstTrade').innerText = `$${worstTrade.toFixed(2)}`;
            document.getElementById('avgPnL').innerText = `$${avgPnL.toFixed(2)}`;
            document.getElementById('profitFactor').innerText = profitFactor;
        }
        
        function closePosition(timestamp) {
            let orders = JSON.parse(localStorage.getItem('orders') || '[]');
            let order = orders.find(o => o.timestamp === timestamp);
            if (order) { 
                order.exitTime = new Date().toISOString(); 
                order.exitPrice = order.entry + (Math.random() - 0.5) * (order.type === 'BUY' ? 20 : -20);
                localStorage.setItem('orders', JSON.stringify(orders)); 
                updatePortfolio(); 
                updateHistory(); 
                showToast('Position closed', 'success'); 
            }
        }
        
        // UPI Payment
        function startSubscription(amount, plan) {
            if (!currentUser) { showToast('Please login first', 'error'); showLogin(); return; }
            showToast(`Proceed to pay ₹${amount} for ${plan} plan via UPI`, 'info');
            const upiLink = `upi://pay?pa=quantpro@okhdfcbank&pn=QuantPro&am=${amount}&tn=${plan} Subscription&cu=INR`;
            window.location.href = upiLink;
        }
        
        function copyUPI() { 
            navigator.clipboard.writeText('quantpro@okhdfcbank'); 
            showToast('UPI ID copied! Open any UPI app to pay', 'success'); 
        }
        
        // Auth Functions
        function showLogin() { document.getElementById('loginModal').classList.remove('hidden'); }
        function hideLogin() { document.getElementById('loginModal').classList.add('hidden'); }
        function showSignup() { hideLogin(); document.getElementById('signupModal').classList.remove('hidden'); }
        function hideSignup() { document.getElementById('signupModal').classList.add('hidden'); }
        
        document.getElementById('loginForm')?.addEventListener('submit', (e) => { 
            e.preventDefault(); 
            currentUser = { email: document.getElementById('loginEmail').value }; 
            localStorage.setItem('user', JSON.stringify(currentUser)); 
            hideLogin(); 
            updateAuthUI(); 
            showToast('Login successful!', 'success'); 
            showPage('trading'); 
        });
        
        document.getElementById('signupForm')?.addEventListener('submit', (e) => { 
            e.preventDefault(); 
            currentUser = { email: document.getElementById('signupEmail').value, name: document.getElementById('signupName').value }; 
            localStorage.setItem('user', JSON.stringify(currentUser)); 
            hideSignup(); 
            updateAuthUI(); 
            showToast('Account created!', 'success'); 
            showPage('trading'); 
        });
        
        function logout() { currentUser = null; localStorage.removeItem('user'); updateAuthUI(); showToast('Logged out', 'info'); showPage('dashboard'); }
        function updateAuthUI() { 
            document.getElementById('userStatus').innerText = currentUser ? currentUser.email : ''; 
            document.getElementById('loginBtn').classList.toggle('hidden', !!currentUser); 
            document.getElementById('logoutBtn').classList.toggle('hidden', !currentUser); 
        }
        
        function showPage(page) { 
            ['dashboard', 'trading', 'portfolio', 'history', 'subscription'].forEach(p => document.getElementById(p + 'Page').classList.add('hidden')); 
            document.getElementById(page + 'Page').classList.remove('hidden'); 
            if(page === 'trading') { if(!mainChart) initTradingChart(); } 
            updatePortfolio(); 
            updateHistory(); 
        }
        
        function showToast(msg, type) { 
            let toast = document.createElement('div'); 
            toast.className = `toast ${type === 'error' ? 'bg-red-600' : type === 'success' ? 'bg-green-600' : 'bg-blue-600'} text-white px-6 py-3 rounded-lg shadow-lg`; 
            toast.innerHTML = msg; 
            document.body.appendChild(toast); 
            setTimeout(() => toast.remove(), 3000); 
        }
        
        // Initialize
        let savedUser = localStorage.getItem('user'); 
        if (savedUser) { currentUser = JSON.parse(savedUser); updateAuthUI(); }
        startRealTimePrices();
        showPage('dashboard');
        initTradingChart();
    </script>
</body>
